# ============================================================
# KONFIGURASI ENVIRONMENT VARIABLES — VERCEL + SUPABASE
# ============================================================
# File ini hanya sebagai CONTOH.
# Anda tidak perlu mengedit file ini.
#
# Saat deploy ke Vercel, masukkan variabel-variabel ini
# di bagian Settings -> Environment Variables
# ============================================================

# URL dari Supabase Anda
SUPABASE_URL=https://[ID_PROJECT_ANDA].supabase.co

# Kunci publik (anon) untuk Supabase (digunakan untuk submit data)
SUPABASE_ANON_KEY=eyJhbGci...

# Kunci rahasia (service_role) untuk Supabase (digunakan oleh admin untuk membaca data)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

